<resources>
    <!-- Base application theme – NO ACTION BAR -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Core Material colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- These were missing — Material widgets (BottomNavigationView, etc.)
             read these directly and default to black when undefined. -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Modern Font -->
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <!-- Bold text appearance -->
    <style name="TextAppearance.Bold" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- Bottom tab label style — smaller size + tight letter spacing prevents clipping at 5 tabs -->
    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>
    <style name="TabTextAppearanceSmall" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>

    <!-- Theme for Splash Screen -->
    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>